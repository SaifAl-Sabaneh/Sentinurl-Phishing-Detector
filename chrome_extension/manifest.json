{
  "manifest_version": 3,
  "name": "SentinURL Web Protection",
  "version": "1.1",
  "description": "Real-time AI-powered phishing detection powered by the SentinURL Engine.",
  "permissions": [
    "activeTab",
    "webNavigation",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SentinURL Dashboard"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
